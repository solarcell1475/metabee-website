Options -Indexes
DirectoryIndex index.html
DirectorySlash Off

<IfModule mod_rewrite.c>
RewriteEngine On

# If Apache resolves a clean route to a real directory generated by Next.js export
# (e.g. /about-us/), serve its sibling HTML file instead.
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} ^/(.+?)/?$
RewriteCond %{DOCUMENT_ROOT}/%1.html -f
RewriteRule ^ %1.html [L]

# Keep direct file requests untouched (e.g. .css, .js, .png, .pdf, .html).
RewriteCond %{REQUEST_URI} \.[A-Za-z0-9]{1,8}$ [OR]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Map extensionless routes to exported HTML pages, including nested routes.
# Examples:
# /about-us            -> /about-us.html
# /products/navkit-s   -> /products/navkit-s.html
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>
